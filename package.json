    "i18next-http-backend": "3.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.2",
    "react-toastify": "11.0.5",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
